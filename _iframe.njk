---
permalink: "{{ eleventyNavigation.data.iframe | replace('https://picocss.com/', '/') | replace('/docs/', '/css/') }}/"

pagination:
  data: iframes
  size: 1
  alias: eleventyNavigation
  addAllPagesToCollections: true

site:
  inline_styles:
    - |-
      main { display: flex; overflow: clip; padding: 0 !important }
      iframe { width: 100%; margin: -160px auto 0 auto }
      footer { display: none }
---

<iframe
  src="{{ iframe }}"
  style="{{ 'max-width: 1023px' if eleventyNavigation.key != 'Examples' }}"
></iframe>
